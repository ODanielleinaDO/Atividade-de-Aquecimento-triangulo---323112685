import java.util.*;

public class AnalisadorCodigo {

    public static void main(String[] args) {

        String codigo = """
        public class StarRectangle {
        public void printRectangle(int n) {
        for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
        System.out.print(" * ");
        }
        System.out.println();
        }
        }
        public void printBottonLeftTriangle(int n) {
        for (int i = 0; i < n; i++) {
        for (int j = 0; j <= i; j++) {
        System.out.print(" * ");
        }
        System.out.println();
        }
        }
        public void printTopRightTriangle(int n) {
        for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
        if (j < i)
        System.out.print(" ");
        else
        System.out.print(" * ");
        }
        System.out.println();
        }
        }
        }
        """;

        Set<String> reservadas = new HashSet<>(Arrays.asList(
                "if", "else", "while", "for", "return",
                "int", "System", "out", "print",
                "public", "class"
        ));

        String[] palavrasArray = codigo.split("[^a-zA-Z]+");

        Set<String> palavrasCodigo = new HashSet<>();

        for (String p : palavrasArray) {
            if (!p.isEmpty()) {
                palavrasCodigo.add(p);
            }
        }

        Set<String> reservadasPresentes = new HashSet<>(palavrasCodigo);
        reservadasPresentes.retainAll(reservadas);

        Set<String> identificadores = new HashSet<>(palavrasCodigo);
        identificadores.removeAll(reservadas);

        System.out.println(reservadasPresentes);
        System.out.println(identificadores);
    }
}
